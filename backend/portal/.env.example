# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (PostgreSQL) — required; there is no SQLite fallback
# Example: createdb portal
DB_NAME=portal
DB_USER=postgres
# Required on most installs: password for the PostgreSQL user (fe_sendauth: no password supplied = set this)
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
# Optional: DB_SSLMODE=require

# Tests use SQLite by default so the suite can run without a local PostgreSQL instance.
USE_SQLITE_FOR_TESTS=true

# Email (Gmail SMTP)
# 1) Enable 2-Step Verification on the Google account.
# 2) Create an App Password: https://myaccount.google.com/apppasswords → Mail / Other → copy 16 chars.
# 3) Put it in EMAIL_HOST_PASSWORD (no spaces). DEFAULT_FROM_EMAIL must match EMAIL_HOST_USER for Gmail.
# If EMAIL_HOST_PASSWORD is empty, Django uses the console backend — nothing is delivered, only printed in the terminal.
EMAIL_HOST_USER=qedamaitechnologies@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=qedamaitechnologies@gmail.com
# Optional: EMAIL_PORT=587  EMAIL_USE_TLS=true  EMAIL_USE_SSL=false

# Links in verification / password-reset emails (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Production: set true when serving over HTTPS
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# Sign in with Google — create an OAuth 2.0 "Web client" in Google Cloud Console and paste the client ID
# (same value in frontend as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Frontend only (Vite): copy of GOOGLE_CLIENT_ID for the browser build
# VITE_GOOGLE_CLIENT_ID=
